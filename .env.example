# Copy to .env and fill in. Never commit the real .env.
#
# Postgres connection (local dev + the routine). In production, Vercel's Neon
# integration injects WATCHLIST_DATABASE_URL automatically — the code reads either.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# API keys are loaded from ~/equity-research-agent/.env automatically (FINNHUB_API_KEY,
# etc.). Set WATCHLIST_ENV_FILE to point elsewhere, or define the keys here instead.
# FINNHUB_API_KEY=...

# Web app gate (set in Vercel env for production; leave unset locally to keep it open).
# APP_PASSCODE=choose-a-passcode
